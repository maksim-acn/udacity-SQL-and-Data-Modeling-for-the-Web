# ============================================================================
# CREDENTIALS (DO NOT COMMIT REAL VALUES - USE .env FILE)
# ============================================================================
DATA_NODE_IP=192.168.x.x   # Data Node in local network
POSTGRES_PORT=5432

# --- PostgreSQL (on local network data node) ---
# Centralized database for n8n, Phoenix, and other services
POSTGRES_USER=''
POSTGRES_PASSWORD=''
POSTGRES_DB='udacity'

# n8n Database Configuration
DB_POSTGRESDB_HOST=${DATA_NODE_IP}
DB_POSTGRESDB_PORT=${POSTGRES_PORT}
DB_POSTGRESDB_DATABASE='udacity'
DB_POSTGRESDB_USER=${POSTGRES_USER}
DB_POSTGRESDB_PASSWORD=${POSTGRES_PASSWORD}